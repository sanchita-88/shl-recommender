# Copy to .env and fill in before running locally
# For Render: set these in the Environment section of your service dashboard

# ── Required ──────────────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional overrides ────────────────────────────────────────────────────────
LLM_PROVIDER=gemini              # gemini | openai  (openai = any OpenAI-compatible)
GEMINI_MODEL=gemini-2.0-flash    # gemini-2.0-flash | gemini-1.5-flash | gemini-1.5-pro
EMBED_MODEL=all-MiniLM-L6-v2     # sentence-transformers model name

# If LLM_PROVIDER=openai (e.g. Groq):
# OPENAI_API_KEY=your_groq_key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
